{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Complete Project",
            "dependsOn": [
                "Trust Engine",
                "Decision Engine",
                "Dashboard"
            ],
            "dependsOrder": "parallel"
        },
        {
            "label": "Trust Engine",
            "type": "shell",
            "command": "uvicorn main:app --reload",
            "options": {
                "cwd": "${workspaceFolder}/trust-engine"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Decision Engine",
            "type": "shell",
            "command": "python main.py",
            "options": {
                "cwd": "${workspaceFolder}/decision-engine"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Dashboard",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/dashboard"
            },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}